<%# Append the new item to the appropriate category column %>
<%= turbo_stream.append "#{@item.category}-items" do %>
  <%= render 'hotwire/items/item', item: @item, retro: @retro %>
<% end %>

<%# Clear the form by replacing it with a fresh one %>
<%= turbo_stream.replace "new-#{@item.category}-item-form" do %>
  <div id="new-<%= @item.category %>-item-form" class="mb-4">
    <%= form_with model: Item.new, url: retro_items_path(@retro), class: 'flex space-x-2' do |f| %>
      <%= f.hidden_field :category, value: @item.category %>
      <%= f.text_field :description,
          placeholder: "Add a #{@item.category} item...",
          class: 'flex-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-teal-500 focus:ring-teal-500 text-sm',
          autocomplete: 'off' %>
      <%= f.submit 'Add',
          class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white #{category_button_class(@item.category)} focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500 shadow-sm transition-colors" %>
    <% end %>
  </div>
<% end %>
