<%# Update the highlighted item panel %>
<%= turbo_stream.replace "highlighted-item" do %>
  <div id="highlighted-item">
    <div class="bg-amber-100 border-b-2 border-amber-300 px-4 py-4">
      <div class="max-w-4xl mx-auto flex items-center justify-between">
        <div class="flex items-center space-x-4">
          <span class="text-3xl"><%= category_emoji(@item.category) %></span>
          <div>
            <p class="text-lg text-gray-900"><%= @item.description %></p>
            <p class="text-sm text-gray-500"><%= @item.vote_count %> votes</p>
          </div>
        </div>
        <div class="flex items-center space-x-2">
          <%= button_to done_retro_item_path(@retro, @item), method: :patch, class: 'px-4 py-2 text-sm font-medium rounded bg-green-500 text-white hover:bg-green-600 transition-colors' do %>
            ✓ Done
          <% end %>
          <%= button_to unhighlight_retro_item_path(@retro, @item), method: :delete, class: 'px-4 py-2 text-sm font-medium rounded bg-gray-200 text-gray-700 hover:bg-gray-300 transition-colors' do %>
            Cancel
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<%# Update the item to show highlight ring %>
<%= turbo_stream.replace dom_id(@item) do %>
  <%= render 'hotwire/items/item', item: @item, retro: @retro %>
<% end %>
