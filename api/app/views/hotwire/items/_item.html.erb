<%# locals: (item:, retro:) %>
<%= turbo_frame_tag dom_id(item) do %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 <%= 'opacity-50 line-through' if item.done? %> <%= 'ring-2 ring-blue-500' if retro.highlighted_item_id == item.id %>"
       data-controller="item"
       data-item-editing-value="false"
       id="<%= dom_id(item) %>">

    <%# Display Mode %>
    <div data-item-target="display" class="<%= 'hidden' if false %>">
      <div class="flex items-start justify-between">
        <p class="text-gray-900 flex-1" data-item-target="description"><%= item.description %></p>

        <%# Item Actions Menu %>
        <div class="ml-2 flex items-center space-x-1">
          <%# Vote Button %>
          <%= button_to vote_hotwire_retro_item_path(retro, item),
              method: :post,
              class: 'inline-flex items-center p-1.5 text-gray-400 hover:text-green-600 hover:bg-green-50 rounded transition-colors',
              data: { controller: 'vote', action: 'click->vote#vote' } do %>
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
            </svg>
            <span class="ml-1 text-sm" data-vote-target="count"><%= item.vote_count %></span>
          <% end %>

          <%# Highlight Button (if not done) %>
          <% unless item.done? %>
            <%= button_to highlight_hotwire_retro_item_path(retro, item),
                method: :post,
                class: 'inline-flex items-center p-1.5 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded transition-colors',
                title: 'Discuss this item' do %>
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
            <% end %>
          <% end %>

          <%# Edit Button %>
          <button type="button"
                  class="inline-flex items-center p-1.5 text-gray-400 hover:text-yellow-600 hover:bg-yellow-50 rounded transition-colors"
                  data-action="click->item#edit"
                  title="Edit item">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </button>

          <%# Delete Button %>
          <%= button_to hotwire_retro_item_path(retro, item),
              method: :delete,
              data: { turbo_confirm: 'Delete this item?' },
              class: 'inline-flex items-center p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded transition-colors',
              title: 'Delete item' do %>
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          <% end %>
        </div>
      </div>

      <%# Item Metadata %>
      <div class="mt-2 flex items-center text-xs text-gray-500">
        <% if item.done? %>
          <span class="inline-flex items-center text-green-600">
            <svg class="h-3 w-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Done
          </span>
        <% end %>
      </div>
    </div>

    <%# Edit Mode %>
    <div data-item-target="form" class="hidden">
      <%= form_with model: item, url: hotwire_retro_item_path(retro, item), method: :patch, data: { action: 'keydown->item#keydown' } do |f| %>
        <div class="space-y-3">
          <%= f.text_area :description,
              value: item.description,
              rows: 3,
              data: { item_target: 'input' },
              class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm' %>
          <div class="flex justify-end space-x-2">
            <button type="button"
                    class="px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-100 rounded"
                    data-action="click->item#cancel">
              Cancel
            </button>
            <%= f.submit 'Save',
                data: { action: 'click->item#save' },
                class: 'px-3 py-1.5 text-sm text-white bg-blue-600 hover:bg-blue-700 rounded' %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
