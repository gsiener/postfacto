<%# locals: (item:, retro:) %>
<%= turbo_frame_tag dom_id(item) do %>
  <div class="bg-white rounded-lg shadow-sm border-l-4 <%= category_border_class(item.category) %> p-3 <%= 'ring-2 ring-amber-400' if retro.highlighted_item_id == item.id %> <%= 'opacity-60' if item.done? %>"
       data-controller="item"
       id="item-card-<%= item.id %>">

    <%# Display Mode %>
    <div data-item-target="display">
      <div class="flex items-start justify-between">
        <p class="text-gray-800 text-sm flex-1 <%= 'line-through' if item.done? %>"><%= item.description %></p>

        <div class="ml-3 flex items-center space-x-1 shrink-0">
          <%# Vote Button %>
          <%= button_to vote_retro_item_path(retro, item),
              method: :post,
              class: 'inline-flex items-center px-2 py-1 text-xs text-gray-500 hover:text-teal-600 hover:bg-teal-50 rounded transition-colors',
              data: { controller: 'vote', action: 'click->vote#vote' } do %>
            <span class="mr-1">👍</span>
            <span data-vote-target="count"><%= item.vote_count %></span>
          <% end %>

          <% unless item.done? %>
            <%# Discuss Button %>
            <%= button_to highlight_retro_item_path(retro, item),
                method: :post,
                class: 'inline-flex items-center p-1 text-gray-400 hover:text-amber-500 hover:bg-amber-50 rounded transition-colors',
                title: 'Discuss' do %>
              💬
            <% end %>
          <% end %>

          <%# Edit Button %>
          <button type="button"
                  class="inline-flex items-center p-1 text-gray-400 hover:text-blue-500 hover:bg-blue-50 rounded transition-colors"
                  data-action="click->item#edit"
                  title="Edit">
            ✏️
          </button>

          <%# Delete Button %>
          <%= button_to retro_item_path(retro, item),
              method: :delete,
              data: { turbo_confirm: 'Delete this item?' },
              class: 'inline-flex items-center p-1 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded transition-colors',
              title: 'Delete' do %>
            🗑️
          <% end %>
        </div>
      </div>

      <% if item.done? %>
        <div class="mt-1 text-xs text-green-600">✓ Done</div>
      <% end %>
    </div>

    <%# Edit Mode %>
    <div data-item-target="form" class="hidden">
      <%= form_with model: item, url: retro_item_path(retro, item), method: :patch, data: { action: 'keydown->item#keydown' } do |f| %>
        <div class="space-y-2">
          <%= f.text_field :description,
              value: item.description,
              data: { item_target: 'input' },
              class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-teal-500 focus:ring-teal-500 text-sm' %>
          <div class="flex justify-end space-x-2">
            <button type="button"
                    class="px-3 py-1 text-xs text-gray-600 hover:bg-gray-100 rounded"
                    data-action="click->item#cancel">
              Cancel
            </button>
            <%= f.submit 'Save',
                class: 'px-3 py-1 text-xs text-white bg-teal-500 hover:bg-teal-600 rounded' %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
