<%# locals: (item:, retro:) %>
<%= turbo_frame_tag dom_id(item) do %>
  <div class="bg-white rounded shadow-sm p-3 <%= 'ring-2 ring-amber-400' if retro.highlighted_item_id == item.id %> <%= 'opacity-50' if item.done? %>"
       data-controller="item"
       id="item-card-<%= item.id %>">

    <%# Display Mode %>
    <div data-item-target="display">
      <div class="flex items-start">
        <%# Vote button - Heart style like original %>
        <%= button_to vote_retro_item_path(retro, item),
            method: :post,
            class: 'flex-shrink-0 mr-3 text-gray-400 hover:text-red-500 transition-colors',
            data: { controller: 'vote', action: 'click->vote#vote' } do %>
          <div class="flex flex-col items-center">
            <span class="text-lg">❤️</span>
            <span class="text-xs text-gray-600" data-vote-target="count"><%= item.vote_count %></span>
          </div>
        <% end %>

        <%# Item text %>
        <p class="flex-1 text-gray-800 text-sm <%= 'line-through' if item.done? %>"><%= item.description %></p>

        <%# Action buttons %>
        <div class="flex-shrink-0 ml-2 flex items-center space-x-1">
          <% unless item.done? %>
            <%# Discuss Button %>
            <%= button_to highlight_retro_item_path(retro, item),
                method: :post,
                class: 'p-1 text-gray-400 hover:text-amber-500 transition-colors',
                title: 'Discuss' do %>
              💬
            <% end %>
          <% end %>

          <%# Edit Button %>
          <button type="button"
                  class="p-1 text-gray-400 hover:text-blue-500 transition-colors"
                  data-action="click->item#edit"
                  title="Edit">
            ✏️
          </button>

          <%# Delete Button %>
          <%= button_to retro_item_path(retro, item),
              method: :delete,
              data: { turbo_confirm: 'Delete this item?' },
              class: 'p-1 text-gray-400 hover:text-red-500 transition-colors',
              title: 'Delete' do %>
            🗑️
          <% end %>
        </div>
      </div>

      <% if item.done? %>
        <div class="mt-1 text-xs text-green-600">✓ Done</div>
      <% end %>
    </div>

    <%# Edit Mode %>
    <div data-item-target="form" class="hidden">
      <%= form_with model: item, url: retro_item_path(retro, item), method: :patch, data: { action: 'keydown->item#keydown' } do |f| %>
        <div class="space-y-2">
          <%= f.text_field :description,
              value: item.description,
              data: { item_target: 'input' },
              class: 'block w-full rounded border-gray-300 shadow-sm focus:border-teal-500 focus:ring-teal-500 text-sm' %>
          <div class="flex justify-end space-x-2">
            <button type="button"
                    class="px-3 py-1 text-xs text-gray-600 hover:bg-gray-100 rounded"
                    data-action="click->item#cancel">
              Cancel
            </button>
            <%= f.submit 'Save',
                class: 'px-3 py-1 text-xs text-white bg-teal-500 hover:bg-teal-600 rounded' %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
