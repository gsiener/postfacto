<%# locals: (item:, retro:, category: nil) %>
<% category ||= item.category %>
<% is_highlighted = retro.highlighted_item_id == item.id %>
<% colors = category_colors(category) %>
<%= turbo_frame_tag dom_id(item) do %>
  <div class="rounded-md mb-2 <%= 'opacity-50' if item.done? %>"
       style="background-color: <%= colors[:card_bg] %>;"
       data-controller="item"
       id="item-card-<%= item.id %>">

    <%# Display Mode %>
    <div data-item-target="display" class="px-4 py-3">
      <div class="flex items-center">
        <%# Vote button - Heart outline style %>
        <%= button_to vote_retro_item_path(retro, item),
            method: :post,
            class: 'flex-shrink-0 mr-3 hover:scale-105 transition-transform',
            data: { controller: 'vote', action: 'click->vote#vote' } do %>
          <span class="text-gray-400 hover:text-red-400" style="font-size: 18px;" data-vote-target="count">♡</span>
        <% end %>

        <%# Item text - clickable to highlight for discussion %>
        <% if item.done? %>
          <p class="flex-1 text-gray-600 line-through"><%= item.description %></p>
        <% else %>
          <%= button_to highlight_retro_item_path(retro, item),
              method: :post,
              class: 'flex-1 text-left text-gray-800 hover:text-gray-600 cursor-pointer',
              title: 'Click to discuss' do %>
            <%= item.description %>
          <% end %>
        <% end %>

        <%# Edit button on right - gray pencil %>
        <button type="button"
                class="flex-shrink-0 ml-2 text-gray-400 hover:text-gray-600 transition-colors"
                data-action="click->item#edit"
                title="Edit"
                style="font-size: 14px;">
          ✎
        </button>
      </div>
    </div>

    <%# Edit Mode %>
    <div data-item-target="form" class="hidden">
      <%= form_with model: item, url: retro_item_path(retro, item), method: :patch, data: { action: 'keydown->item#keydown' } do |f| %>
        <div class="space-y-2">
          <%= f.text_field :description,
              value: item.description,
              data: { item_target: 'input' },
              class: 'block w-full rounded border-gray-300 shadow-sm focus:border-teal-500 focus:ring-teal-500 text-sm' %>
          <div class="flex justify-end space-x-2">
            <button type="button"
                    class="px-3 py-1 text-xs text-gray-600 hover:bg-gray-100 rounded"
                    data-action="click->item#cancel">
              Cancel
            </button>
            <%= f.submit 'Save',
                class: 'px-3 py-1 text-xs text-white bg-teal-500 hover:bg-teal-600 rounded' %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
