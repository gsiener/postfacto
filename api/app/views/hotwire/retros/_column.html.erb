<%# locals: (retro:, category:, items:) %>
<div class="retro-column" id="<%= category %>-column">
  <%# Column Header with Emoji %>
  <div class="flex items-center justify-center mb-4">
    <span class="text-3xl mr-2"><%= category_emoji(category) %></span>
    <h2 class="text-lg font-semibold text-gray-700">
      <%= category.capitalize %>
      <span class="text-sm font-normal text-gray-500">(<%= items.count %>)</span>
    </h2>
  </div>

  <%# New Item Form %>
  <div id="new-<%= category %>-item-form" class="mb-4">
    <%= form_with model: Item.new, url: retro_items_path(retro), class: 'flex space-x-2' do |f| %>
      <%= f.hidden_field :category, value: category %>
      <%= f.text_field :description,
          placeholder: "Add a #{category} item...",
          class: 'flex-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-teal-500 focus:ring-teal-500 text-sm',
          autocomplete: 'off' %>
      <%= f.submit 'Add',
          class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white #{category_button_class(category)} focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500 shadow-sm transition-colors" %>
    <% end %>
  </div>

  <%# Items List %>
  <div id="<%= category %>-items" class="space-y-3">
    <%= render partial: 'hotwire/items/item', collection: items, as: :item, locals: { retro: retro } %>
  </div>
</div>
