<% content_for(:title) { "Settings - #{@retro.name}" } %>

<div class="min-h-screen bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-lg mx-auto">
    <div class="bg-white shadow rounded-lg">
      <div class="px-6 py-8">
        <div class="flex items-center justify-between mb-6">
          <h1 class="text-2xl font-bold text-gray-900">Retro Settings</h1>
          <%= link_to retro_path(@retro), class: 'text-sm text-blue-600 hover:text-blue-500' do %>
            &larr; Back to Retro
          <% end %>
        </div>

        <%= form_with model: @retro, url: retro_path(@retro), method: :patch, class: 'space-y-6' do |f| %>
          <% if @retro.errors.any? %>
            <div class="rounded-md bg-red-50 p-4">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div class="ml-3">
                  <h3 class="text-sm font-medium text-red-800">There were errors with your submission:</h3>
                  <div class="mt-2 text-sm text-red-700">
                    <ul class="list-disc pl-5 space-y-1">
                      <% @retro.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <div>
            <%= f.label :name, 'Retro Name', class: 'block text-sm font-medium text-gray-700' %>
            <div class="mt-1">
              <%= f.text_field :name,
                  class: 'appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm' %>
            </div>
          </div>

          <div>
            <%= f.label :video_link, 'Video Call Link', class: 'block text-sm font-medium text-gray-700' %>
            <div class="mt-1">
              <%= f.url_field :video_link,
                  placeholder: 'https://meet.google.com/...',
                  class: 'appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm' %>
            </div>
            <p class="mt-1 text-sm text-gray-500">Add a link to your video call for easy access.</p>
          </div>

          <div class="border-t border-gray-200 pt-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Privacy Settings</h3>

            <div class="space-y-4">
              <div class="flex items-start">
                <%= f.check_box :is_private, class: 'h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded mt-1' %>
                <div class="ml-3">
                  <%= f.label :is_private, 'Make this retro private', class: 'block text-sm font-medium text-gray-700' %>
                  <p class="text-sm text-gray-500">Only people with the password can access this retro.</p>
                </div>
              </div>

              <div class="flex items-start">
                <%= f.check_box :is_magic_link_enabled, class: 'h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded mt-1' %>
                <div class="ml-3">
                  <%= f.label :is_magic_link_enabled, 'Enable magic link', class: 'block text-sm font-medium text-gray-700' %>
                  <p class="text-sm text-gray-500">Generate a shareable link that doesn't require a password.</p>
                </div>
              </div>

              <% if @retro.magic_link_enabled? %>
                <div class="ml-7 p-4 bg-gray-50 rounded-md">
                  <p class="text-sm font-medium text-gray-700 mb-2">Magic Link</p>
                  <div class="flex items-center space-x-2">
                    <input type="text" readonly value="<%= retro_magic_link_url(@retro, token: @retro.join_token) %>" class="flex-1 text-sm bg-white border border-gray-300 rounded px-3 py-2 text-gray-600">
                    <button type="button" onclick="navigator.clipboard.writeText(this.previousElementSibling.value)" class="px-3 py-2 text-sm text-blue-600 hover:text-blue-500 border border-blue-600 rounded hover:bg-blue-50">
                      Copy
                    </button>
                  </div>
                  <p class="mt-2 text-xs text-gray-500">Share this link with your team. Anyone with this link can access the retro without a password.</p>
                </div>
              <% end %>
            </div>
          </div>

          <div class="border-t border-gray-200 pt-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Retro URL</h3>
            <div class="flex items-center text-sm">
              <span class="text-gray-500"><%= request.host_with_port %>/retros/</span>
              <span class="font-medium text-gray-900"><%= @retro.slug %></span>
            </div>
          </div>

          <div class="flex justify-end space-x-3 pt-6 border-t border-gray-200">
            <%= link_to 'Cancel', retro_path(@retro), class: 'px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500' %>
            <%= f.submit 'Save Settings',
                class: 'px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
