<%# locals: (retro:, action_items:) %>
<% date_groups = group_action_items_by_date(action_items) %>
<% grouped = date_groups[:grouped] %>
<% group_order = date_groups[:group_order] %>
<div>
  <%# New Action Item Form %>
  <div id="new-action-item-form" class="max-w-md mx-auto mb-8">
    <%= form_with model: ActionItem.new, url: retro_action_items_path(retro), data: { turbo_stream: true } do |f| %>
      <%= f.text_field :description,
          placeholder: "Add an action item",
          class: 'block w-full rounded-md border-0 text-sm py-3 px-4 placeholder-white/70',
          style: 'background-color: #8b9298; color: white;',
          autocomplete: 'off' %>
    <% end %>
  </div>

  <%# Action Items List - Three columns with horizontal flow %>
  <div id="action-items" class="grid grid-cols-3 gap-6">
    <% group_order.each do |date_label| %>
      <div>
        <h3 class="text-sm text-gray-600 mb-3"><%= date_label %></h3>
        <div class="flex flex-wrap gap-2">
          <% (grouped[date_label] || []).each do |action_item| %>
            <%= render 'hotwire/action_items/action_item', action_item: action_item, retro: retro %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
