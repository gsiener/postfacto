<%# locals: (retro:, action_items:) %>
<div class="action-panel" id="action-panel">
  <%# Panel Header %>
  <div class="flex items-center justify-center mb-4">
    <span class="text-3xl mr-2">📋</span>
    <h2 class="text-lg font-semibold text-gray-700">
      Action Items
      <span class="text-sm font-normal text-gray-500">(<%= action_items.count %>)</span>
    </h2>
  </div>

  <%# New Action Item Form %>
  <div id="new-action-item-form" class="mb-4">
    <%= form_with model: ActionItem.new, url: retro_action_items_path(retro), class: 'flex space-x-2' do |f| %>
      <%= f.text_field :description,
          placeholder: "Add an action item...",
          class: 'flex-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm',
          autocomplete: 'off' %>
      <%= f.submit 'Add',
          class: 'inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-purple-500 hover:bg-purple-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 shadow-sm transition-colors' %>
    <% end %>
  </div>

  <%# Action Items List %>
  <div id="action-items" class="space-y-2">
    <%= render partial: 'hotwire/action_items/action_item', collection: action_items, as: :action_item, locals: { retro: retro } %>
  </div>

  <%# Summary %>
  <% completed = action_items.count(&:done?) %>
  <% if action_items.any? %>
    <div class="mt-4 pt-4 border-t border-purple-200">
      <div class="flex items-center justify-between text-sm text-gray-600">
        <span><%= completed %> of <%= action_items.count %> completed</span>
        <div class="w-24 bg-purple-100 rounded-full h-2">
          <div class="bg-purple-500 h-2 rounded-full transition-all" style="width: <%= action_items.any? ? (completed * 100 / action_items.count) : 0 %>%"></div>
        </div>
      </div>
    </div>
  <% end %>
</div>
