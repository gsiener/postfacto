<%# locals: (retro:, category:, items:) %>
<%# New Item Form %>
<div id="new-<%= category %>-item-form" class="mb-3">
  <%= form_with model: Item.new, url: retro_items_path(retro), class: 'flex space-x-2', data: { turbo_stream: true } do |f| %>
    <%= f.hidden_field :category, value: category %>
    <%= f.text_field :description,
        placeholder: "I'm thinking...",
        class: 'flex-1 block w-full rounded border-gray-300 shadow-sm focus:border-teal-500 focus:ring-teal-500 text-sm py-2 px-3',
        autocomplete: 'off' %>
    <%= f.submit 'Add',
        class: "px-4 py-2 text-sm font-medium rounded text-white #{category_button_class(category)} shadow-sm transition-colors" %>
  <% end %>
</div>

<%# Items List %>
<div id="<%= category %>-items" class="space-y-2">
  <%= render partial: 'hotwire/items/item', collection: items, as: :item, locals: { retro: retro, category: category } %>
</div>
