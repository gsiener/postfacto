<% content_for(:title) { @retro.name } %>

<div class="min-h-screen flex flex-col" data-controller="hotkeys" data-hotkeys-retro-id-value="<%= @retro.slug %>">
  <%# Header - White background with text links %>
  <header class="bg-white relative z-10">
    <div class="max-w-full mx-auto px-6 py-4">
      <div class="flex items-center justify-between">
        <div class="w-64"></div>
        <h1 class="text-2xl font-bold" style="color: #4ecdc4;"><%= @retro.name %></h1>
        <div class="flex items-center text-sm" style="gap: 24px;">
          <%= link_to 'Settings', edit_retro_path(@retro), class: 'text-gray-500 hover:text-gray-700' %>
          <%= link_to 'Archives', retro_archives_path(@retro), class: 'text-gray-500 hover:text-gray-700' %>
          <% if @retro.video_link.present? %>
            <%= link_to 'Video', @retro.video_link, target: '_blank', class: 'text-gray-500 hover:text-gray-700' %>
          <% end %>
        </div>
      </div>
    </div>
  </header>

  <%# Highlighted Item Discussion Panel %>
  <div id="highlighted-item">
    <% if @highlighted_item %>
      <div class="bg-amber-100 border-b-2 border-amber-300 px-4 py-4">
        <div class="max-w-4xl mx-auto flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <span class="text-3xl"><%= category_emoji(@highlighted_item.category) %></span>
            <div>
              <p class="text-lg text-gray-900"><%= @highlighted_item.description %></p>
              <p class="text-sm text-gray-500"><%= @highlighted_item.vote_count %> votes</p>
            </div>
          </div>
          <div class="flex items-center space-x-2">
            <%= button_to done_retro_item_path(@retro, @highlighted_item), method: :patch, class: 'px-4 py-2 text-sm font-medium rounded bg-green-500 text-white hover:bg-green-600 transition-colors' do %>
              ✓ Done
            <% end %>
            <%= button_to unhighlight_retro_item_path(@retro, @highlighted_item), method: :delete, class: 'px-4 py-2 text-sm font-medium rounded bg-gray-200 text-gray-700 hover:bg-gray-300 transition-colors' do %>
              Cancel
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <%# Main Content Area %>
  <div class="flex-1 flex flex-col overflow-hidden">
    <%# Three Columns - Happy, Meh, Sad %>
    <div class="flex-1 grid grid-cols-1 md:grid-cols-3 overflow-hidden">
      <% %w[happy meh sad].each do |cat| %>
        <% colors = category_colors(cat) %>
        <% prompt_text = case cat
           when 'happy' then "I'm glad that..."
           when 'meh' then "I'm wondering about..."
           when 'sad' then "It wasn't so great that..."
           end %>
        <% emoji = case cat
           when 'happy' then '😃'
           when 'meh' then '🤨'
           when 'sad' then '😢'
           end %>
        <%# <%= cat.capitalize %> Column %>
        <div class="flex flex-col overflow-hidden relative" style="background-color: <%= colors[:bg] %>;">
          <div class="flex justify-center" style="margin-top: -28px;">
            <span style="font-size: 56px;"><%= emoji %></span>
          </div>
          <div class="px-3 pb-3 pt-1">
            <div id="new-<%= cat %>-item-form" data-controller="input-prompt" data-input-prompt-input-bg-value="<%= colors[:input_bg] %>">
              <div data-input-prompt-target="prompt" class="rounded-md px-4 py-3 mb-3" style="background-color: <%= colors[:prompt_bg] %>;">
                <span class="text-white text-sm"><%= prompt_text %></span>
              </div>
              <%= form_with model: Item.new, url: retro_items_path(@retro), data: { turbo_stream: true } do |f| %>
                <%= f.hidden_field :category, value: cat %>
                <%= f.text_area :description,
                    placeholder: prompt_text,
                    rows: 1,
                    class: 'block w-full rounded-md border-0 text-sm py-3 px-4 resize-none focus:ring-0 transition-all placeholder-gray-400',
                    style: "background-color: #{colors[:input_bg]}; min-height: 44px;",
                    autocomplete: 'off',
                    data: { input_prompt_target: 'input', action: 'focus->input-prompt#focus blur->input-prompt#blur' } %>
              <% end %>
            </div>
          </div>
          <div class="flex-1 overflow-y-auto px-3 pb-3" id="<%= cat %>-column-content">
            <%= render 'hotwire/retros/column_items', retro: @retro, category: cat, items: @items_by_category[cat.to_sym] %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Action Items - Below the columns %>
    <div style="background-color: #e8e4df;">
      <div class="text-center py-4">
        <span class="text-gray-700 font-medium">Action items</span>
      </div>
      <div class="px-6 pb-6">
        <%= render 'hotwire/retros/action_panel_content', retro: @retro, action_items: @action_items %>
      </div>
    </div>
  </div>
</div>

<%# Subscribe to Turbo Streams for real-time updates %>
<%= turbo_stream_from @retro %>
