<% content_for(:title) { @retro.name } %>

<div class="min-h-screen flex flex-col bg-gray-100" data-controller="hotkeys" data-hotkeys-retro-id-value="<%= @retro.slug %>">
  <%# Header - Teal like original Postfacto %>
  <header class="bg-teal-600 shadow-md">
    <div class="max-w-full mx-auto px-4 py-3 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-4">
          <h1 class="text-xl font-semibold text-white"><%= @retro.name %></h1>
          <% if @retro.is_private? %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-teal-700 text-teal-100">
              🔒 Private
            </span>
          <% end %>
        </div>
        <div class="flex items-center space-x-2">
          <% if @retro.video_link.present? %>
            <%= link_to @retro.video_link, target: '_blank', class: 'inline-flex items-center px-3 py-1.5 text-sm font-medium rounded text-teal-100 hover:bg-teal-700 transition-colors' do %>
              📹 Video
            <% end %>
          <% end %>
          <%= link_to edit_retro_path(@retro), class: 'inline-flex items-center px-3 py-1.5 text-sm font-medium rounded text-teal-100 hover:bg-teal-700 transition-colors' do %>
            ⚙️ Settings
          <% end %>
          <%= button_to archive_retro_path(@retro), method: :post, data: { turbo_confirm: 'Archive this retro? All items will be moved to the archive.' }, class: 'inline-flex items-center px-3 py-1.5 text-sm font-medium rounded bg-teal-700 text-white hover:bg-teal-800 transition-colors' do %>
            📦 Archive
          <% end %>
        </div>
      </div>
    </div>
  </header>

  <%# Highlighted Item Discussion Panel %>
  <% if @highlighted_item %>
    <%= turbo_frame_tag "highlighted-item" do %>
      <div class="bg-amber-50 border-b-4 border-amber-400 px-4 py-6 shadow-inner">
        <div class="max-w-4xl mx-auto">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center space-x-2">
                <span class="text-2xl"><%= category_emoji(@highlighted_item.category) %></span>
                <span class="text-sm font-semibold text-amber-700 uppercase tracking-wide">Currently Discussing</span>
              </div>
              <p class="mt-3 text-xl text-gray-900"><%= @highlighted_item.description %></p>
              <p class="mt-2 text-sm text-gray-500"><%= @highlighted_item.vote_count %> votes</p>
            </div>
            <div class="ml-6 flex items-center space-x-2">
              <%= button_to done_retro_item_path(@retro, @highlighted_item), method: :patch, class: 'inline-flex items-center px-4 py-2 text-sm font-medium rounded-md text-white bg-green-500 hover:bg-green-600 shadow transition-colors' do %>
                ✓ Done
              <% end %>
              <%= button_to unhighlight_retro_item_path(@retro, @highlighted_item), method: :delete, class: 'inline-flex items-center px-4 py-2 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-100 shadow transition-colors' do %>
                Cancel
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <%= turbo_frame_tag "highlighted-item" %>
  <% end %>

  <%# Mobile Tabs %>
  <div class="sm:hidden bg-white border-b" data-controller="tabs" data-tabs-active-tab-value="happy">
    <nav class="flex">
      <button type="button" data-tabs-target="tab" data-tabs-tab="happy" data-action="click->tabs#switch" class="flex-1 py-3 text-center text-sm font-medium border-b-2 border-transparent hover:border-green-300 focus:outline-none">
        😊
      </button>
      <button type="button" data-tabs-target="tab" data-tabs-tab="meh" data-action="click->tabs#switch" class="flex-1 py-3 text-center text-sm font-medium border-b-2 border-transparent hover:border-yellow-300 focus:outline-none">
        😐
      </button>
      <button type="button" data-tabs-target="tab" data-tabs-tab="sad" data-action="click->tabs#switch" class="flex-1 py-3 text-center text-sm font-medium border-b-2 border-transparent hover:border-red-300 focus:outline-none">
        😢
      </button>
      <button type="button" data-tabs-target="tab" data-tabs-tab="action" data-action="click->tabs#switch" class="flex-1 py-3 text-center text-sm font-medium border-b-2 border-transparent hover:border-purple-300 focus:outline-none">
        📋
      </button>
    </nav>

    <%# Mobile Content Panels %>
    <div data-tabs-target="panel" data-tabs-panel="happy" class="p-4 bg-green-50">
      <%= render 'hotwire/retros/column', retro: @retro, category: 'happy', items: @items_by_category[:happy] %>
    </div>
    <div data-tabs-target="panel" data-tabs-panel="meh" class="hidden p-4 bg-yellow-50">
      <%= render 'hotwire/retros/column', retro: @retro, category: 'meh', items: @items_by_category[:meh] %>
    </div>
    <div data-tabs-target="panel" data-tabs-panel="sad" class="hidden p-4 bg-red-50">
      <%= render 'hotwire/retros/column', retro: @retro, category: 'sad', items: @items_by_category[:sad] %>
    </div>
    <div data-tabs-target="panel" data-tabs-panel="action" class="hidden p-4 bg-purple-50">
      <%= render 'hotwire/retros/action_panel', retro: @retro, action_items: @action_items %>
    </div>
  </div>

  <%# Desktop Layout - 4 columns like original %>
  <div class="hidden sm:flex flex-1 overflow-hidden">
    <div class="flex-1 overflow-y-auto p-4 bg-green-50">
      <%= render 'hotwire/retros/column', retro: @retro, category: 'happy', items: @items_by_category[:happy] %>
    </div>
    <div class="flex-1 overflow-y-auto p-4 bg-yellow-50">
      <%= render 'hotwire/retros/column', retro: @retro, category: 'meh', items: @items_by_category[:meh] %>
    </div>
    <div class="flex-1 overflow-y-auto p-4 bg-red-50">
      <%= render 'hotwire/retros/column', retro: @retro, category: 'sad', items: @items_by_category[:sad] %>
    </div>
    <div class="w-80 overflow-y-auto p-4 bg-purple-50 border-l border-purple-200">
      <%= render 'hotwire/retros/action_panel', retro: @retro, action_items: @action_items %>
    </div>
  </div>
</div>

<%# Subscribe to Turbo Streams for real-time updates %>
<%= turbo_stream_from @retro %>
