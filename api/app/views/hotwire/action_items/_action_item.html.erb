<%# locals: (action_item:, retro:) %>
<%= turbo_frame_tag dom_id(action_item) do %>
  <div class="inline-flex items-center bg-white rounded px-2 py-1.5"
       style="box-shadow: 0 1px 2px rgba(0,0,0,0.08);"
       data-controller="item"
       id="action-item-card-<%= action_item.id %>">

    <%# Checkbox %>
    <%= button_to toggle_done_retro_action_item_path(retro, action_item),
        method: :patch,
        class: 'flex-shrink-0 mr-2' do %>
      <div class="w-4 h-4 rounded border <%= action_item.done? ? 'bg-teal-500 border-teal-500' : 'border-gray-300 hover:border-teal-400' %> flex items-center justify-center transition-colors">
        <% if action_item.done? %>
          <span class="text-white text-xs">✓</span>
        <% end %>
      </div>
    <% end %>

    <%# Display Mode %>
    <div data-item-target="display" class="flex items-center">
      <span class="text-sm text-gray-700 <%= 'line-through text-gray-400' if action_item.done? %>">
        <%= action_item.description %>
      </span>

      <%# Edit button %>
      <button type="button"
              class="flex-shrink-0 ml-2 text-gray-300 hover:text-gray-500 transition-colors text-xs"
              data-action="click->item#edit"
              title="Edit">
        ✏️
      </button>
    </div>

    <%# Edit Mode %>
    <div data-item-target="form" class="hidden flex-1">
      <%= form_with model: action_item, url: retro_action_item_path(retro, action_item), method: :patch, data: { action: 'keydown->item#keydown' } do |f| %>
        <div class="flex items-center space-x-2">
          <%= f.text_field :description,
              value: action_item.description,
              data: { item_target: 'input' },
              class: 'flex-1 block w-full rounded border-gray-300 shadow-sm focus:border-teal-500 focus:ring-teal-500 text-sm py-1.5' %>
          <button type="button"
                  class="text-gray-400 hover:text-gray-600"
                  data-action="click->item#cancel"
                  title="Cancel">
            ✕
          </button>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
