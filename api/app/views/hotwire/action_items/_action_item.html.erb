<%# locals: (action_item:, retro:) %>
<%= turbo_frame_tag dom_id(action_item) do %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-3 flex items-start space-x-3 <%= 'bg-gray-50' if action_item.done? %>"
       data-controller="item"
       data-item-editing-value="false"
       id="<%= dom_id(action_item) %>">

    <%# Checkbox %>
    <%= button_to toggle_done_hotwire_retro_action_item_path(retro, action_item),
        method: :patch,
        class: 'flex-shrink-0 mt-0.5' do %>
      <div class="w-5 h-5 rounded border-2 <%= action_item.done? ? 'bg-purple-600 border-purple-600' : 'border-gray-300 hover:border-purple-400' %> flex items-center justify-center transition-colors">
        <% if action_item.done? %>
          <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
        <% end %>
      </div>
    <% end %>

    <%# Display Mode %>
    <div data-item-target="display" class="flex-1 min-w-0">
      <p class="text-sm text-gray-900 <%= 'line-through text-gray-500' if action_item.done? %>" data-item-target="description">
        <%= action_item.description %>
      </p>
    </div>

    <%# Edit Mode %>
    <div data-item-target="form" class="hidden flex-1 min-w-0">
      <%= form_with model: action_item, url: hotwire_retro_action_item_path(retro, action_item), method: :patch, data: { action: 'keydown->item#keydown' } do |f| %>
        <div class="flex space-x-2">
          <%= f.text_field :description,
              value: action_item.description,
              data: { item_target: 'input' },
              class: 'flex-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm' %>
          <button type="button"
                  class="px-2 py-1 text-xs text-gray-500 hover:bg-gray-100 rounded"
                  data-action="click->item#cancel">
            Cancel
          </button>
          <%= f.submit 'Save',
              data: { action: 'click->item#save' },
              class: 'px-2 py-1 text-xs text-white bg-blue-600 hover:bg-blue-700 rounded' %>
        </div>
      <% end %>
    </div>

    <%# Action Buttons %>
    <div data-item-target="display" class="flex-shrink-0 flex items-center space-x-1">
      <button type="button"
              class="p-1 text-gray-400 hover:text-yellow-600 hover:bg-yellow-50 rounded transition-colors"
              data-action="click->item#edit"
              title="Edit">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
      </button>

      <%= button_to hotwire_retro_action_item_path(retro, action_item),
          method: :delete,
          data: { turbo_confirm: 'Delete this action item?' },
          class: 'p-1 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded transition-colors',
          title: 'Delete' do %>
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      <% end %>
    </div>
  </div>
<% end %>
