<%# Append the new action item %>
<%= turbo_stream.append "action-items" do %>
  <%= render 'hotwire/action_items/action_item', action_item: @action_item, retro: @retro %>
<% end %>

<%# Clear the form %>
<%= turbo_stream.replace "new-action-item-form" do %>
  <%= form_with model: ActionItem.new, url: retro_action_items_path(@retro), class: 'mb-4' do |f| %>
    <div class="flex space-x-2">
      <%= f.text_field :description,
          placeholder: "Add an action item...",
          class: 'flex-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm' %>
      <%= f.submit 'Add',
          class: 'inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500' %>
    </div>
  <% end %>
<% end %>
