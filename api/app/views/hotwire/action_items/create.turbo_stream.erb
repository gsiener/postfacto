<%# Append the new action item %>
<%= turbo_stream.append "action-items" do %>
  <%= render 'hotwire/action_items/action_item', action_item: @action_item, retro: @retro %>
<% end %>

<%# Clear the form by replacing it with a fresh one %>
<%= turbo_stream.replace "new-action-item-form" do %>
  <div id="new-action-item-form" class="mb-4">
    <%= form_with model: ActionItem.new, url: retro_action_items_path(@retro), class: 'flex space-x-2' do |f| %>
      <%= f.text_field :description,
          placeholder: "Add an action item...",
          class: 'flex-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm',
          autocomplete: 'off' %>
      <%= f.submit 'Add',
          class: 'inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-purple-500 hover:bg-purple-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 shadow-sm transition-colors' %>
    <% end %>
  </div>
<% end %>
